---
interface Props {
  label?: string;
  class?: string;
}

const { label, class: className } = Astro.props;
---

<div class:list={['mb-12 md:mb-16', className]}>
  {label && (
    <span class="mb-4 block font-mono text-sm uppercase tracking-wider text-accent">
      {label}
    </span>
  )}
  <h2 class="text-3xl font-bold text-text-primary md:text-4xl">
    <slot />
  </h2>
</div>
