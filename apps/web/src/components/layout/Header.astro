---
import { navigation } from '../../data/navigation';
---

<header class="fixed top-0 z-50 w-full border-b border-border-primary/50 bg-bg-primary/80 backdrop-blur-xl">
  <nav class="mx-auto flex max-w-7xl items-center justify-between px-4 py-4">
    <a href="/" class="flex items-center gap-2 text-text-primary" aria-label="Ping home">
      <!-- Founder-provided logo (verbatim, fill=#0E1B36).
           Wrapped in a white rounded plate so the dark-navy mark has
           proper contrast against the site's dark header background. -->
      <span class="inline-flex items-center justify-center rounded-xl bg-white px-2 py-1.5 shadow-sm">
        <svg width="44" height="37" viewBox="0 0 245 206" fill="#0E1B36" aria-hidden="true" class="flex-shrink-0">
          <g transform="translate(0.000000,206.000000) scale(1.000000,-1.000000)">
            <path d="M77 204 c-8 -4 -8 -17 -1 -21 2 -1 16 -2 58 -2 55 0 55 0 61 -4 37-17 31 -74 -8 -85 -4 -1 -15 -1 -41 -1 -48 0 -46 1 -55 -24 -1 -4 -4 -10 -6-15 -2 -4 -4 -8 -4 -9 0 0 -1 -3 -3 -6 -9 -20 -9 -28 0 -32 8 -3 13 1 19 1520 50 16 46 56 47 40 1 41 1 53 7 42 21 51 79 19 112 -9 9 -14 12 -29 17 -9 3-113 4 -119 1z"/>
          </g>
          <rect x="26" y="61" width="112" height="24" rx="12"/>
          <rect x="0" y="115" width="62" height="24" rx="12"/>
        </svg>
      </span>
      <span class="text-xl font-bold">Ping</span>
    </a>

    <ul class="hidden items-center gap-8 md:flex">
      {navigation.map((item) => (
        <li>
          <a
            href={item.href}
            class="text-sm text-text-secondary transition-colors duration-200 hover:text-text-primary"
          >
            {item.label}
          </a>
        </li>
      ))}
    </ul>

    <div class="flex items-center gap-3">
      <a
        href="https://app.ping.cash"
        class="hidden rounded-full bg-gradient-to-r from-emerald-500 to-cyan-400 px-5 py-2 text-sm font-medium text-white shadow-md transition-all duration-200 hover:shadow-lg hover:scale-105 md:inline-block"
      >
        Open app
      </a>
      <button
        type="button"
        class="md:hidden text-text-primary"
        aria-label="Open menu"
        data-mobile-toggle
      >
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <line x1="3" y1="6" x2="21" y2="6" />
          <line x1="3" y1="12" x2="21" y2="12" />
          <line x1="3" y1="18" x2="21" y2="18" />
        </svg>
      </button>
    </div>
  </nav>

  <div
    class="mobile-menu hidden border-t border-border-primary/50 bg-bg-primary md:hidden"
    data-mobile-menu
  >
    <ul class="space-y-3 px-4 py-4">
      {navigation.map((item) => (
        <li>
          <a
            href={item.href}
            class="block text-base text-text-secondary hover:text-text-primary"
          >
            {item.label}
          </a>
        </li>
      ))}
      <li class="pt-3">
        <a
          href="https://app.ping.cash"
          class="inline-block rounded-full bg-gradient-to-r from-emerald-500 to-cyan-400 px-5 py-2 text-sm font-medium text-white"
        >
          Open app
        </a>
      </li>
    </ul>
  </div>
</header>

<script>
  const toggle = document.querySelector('[data-mobile-toggle]');
  const menu = document.querySelector('[data-mobile-menu]');
  toggle?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });
</script>
