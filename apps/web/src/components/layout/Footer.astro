---
const year = new Date().getFullYear();
---

<footer class="border-t border-border-primary bg-bg-primary">
  <div class="mx-auto max-w-7xl px-4 py-16">
    <div class="grid gap-12 md:grid-cols-5">
      <div>
        <a href="/" class="flex items-center gap-2 text-text-primary">
          <img src="/logo.svg" alt="" width="34" height="29" />
          <span class="text-lg font-bold">Ping</span>
        </a>
        <p class="mt-4 text-sm text-text-tertiary leading-relaxed">
          Send money instantly worldwide.<br />
          P2P, social, low fee.<br />
          Recipients get cash in seconds.
        </p>
      </div>

      <div>
        <h3 class="mb-4 font-medium text-text-primary">Send money</h3>
        <ul class="flex flex-col gap-2">
          <li><a href="/#send" class="text-sm text-text-tertiary hover:text-text-secondary transition-colors">Send money</a></li>
          <li><a href="/#countries" class="text-sm text-text-tertiary hover:text-text-secondary transition-colors">Where you can send</a></li>
          <li><a href="/#fees" class="text-sm text-text-tertiary hover:text-text-secondary transition-colors">Fees & rates</a></li>
          <li><a href="https://app.ping.cash" class="text-sm text-text-tertiary hover:text-text-secondary transition-colors">Open app</a></li>
        </ul>
      </div>

      <div>
        <h3 class="mb-4 font-medium text-text-primary">Support</h3>
        <ul class="flex flex-col gap-2">
          <li><a href="/help" class="text-sm text-text-tertiary hover:text-text-secondary transition-colors">Help center</a></li>
          <li><a href="mailto:support@ping.cash" class="text-sm text-text-tertiary hover:text-text-secondary transition-colors">support@ping.cash</a></li>
          <li><a href="mailto:hello@ping.cash" class="text-sm text-text-tertiary hover:text-text-secondary transition-colors">hello@ping.cash</a></li>
          <li><a href="mailto:partnerships@ping.cash" class="text-sm text-text-tertiary hover:text-text-secondary transition-colors">partnerships@ping.cash</a></li>
        </ul>
      </div>

      <div>
        <h3 class="mb-4 font-medium text-text-primary">Company</h3>
        <ul class="flex flex-col gap-2">
          <li><a href="/about" class="text-sm text-text-tertiary hover:text-text-secondary transition-colors">About</a></li>
          <li><a href="/contact" class="text-sm text-text-tertiary hover:text-text-secondary transition-colors">Contact</a></li>
          <li><a href="https://github.com/ping-cash" class="text-sm text-text-tertiary hover:text-text-secondary transition-colors" target="_blank" rel="noopener">GitHub</a></li>
        </ul>
      </div>

      <div>
        <h3 class="mb-4 font-medium text-text-primary">Trust</h3>
        <ul class="flex flex-col gap-2">
          <li><span class="text-sm text-text-tertiary">Open source code</span></li>
          <li><span class="text-sm text-text-tertiary">Non-custodial wallet</span></li>
          <li><span class="text-sm text-text-tertiary">0.4% fee · no FX markup</span></li>
          <li><span class="text-sm text-text-tertiary">Pyth on-chain pricing</span></li>
        </ul>
      </div>
    </div>

    <div class="mt-12 flex flex-col items-center justify-between gap-4 border-t border-border-primary pt-8 md:flex-row">
      <p class="text-sm text-text-tertiary">
        &copy; {year} Ping. Built on the openova.io Sovereign platform.
      </p>
      <p class="text-sm text-text-tertiary">
        Send money like a message.
      </p>
    </div>
  </div>
</footer>
