# ============================================
# Ping Platform — Environment Variables
# ============================================
# This file documents the env vars each service consumes. In production
# values come from OpenBao on openova-private via External Secrets Operator;
# the Sovereign mounts a Secret resource per pod. See:
#   docs/SECURITY.md § Secrets Management
#   docs/adr/0006-deployment-via-openova-sovereign.md
#
# For local TS development on the bastion, leave these empty — unit tests
# stub external clients and don't need real values.

# Environment
NODE_ENV=development
LOG_LEVEL=debug

# ============================================
# Database Connection Strings (OpenBao-sourced in production)
# ============================================
# Postgres CNPG endpoint provided by the Sovereign:
POSTGRES_URL=
# MongoDB ReplicaSet endpoint provided by the Sovereign:
MONGODB_URL=
# Redis Sentinel endpoint provided by the Sovereign:
REDIS_URL=

# ============================================
# Event Streaming
# ============================================
# Redpanda brokers provided by the Sovereign:
KAFKA_BROKERS=
KAFKA_CLIENT_ID=ping-platform
KAFKA_GROUP_ID=ping-consumers

# ============================================
# External Services (all provisioned; values in OpenBao)
# ============================================

# Privy (Wallet Infrastructure — MPC 2-of-3)
PRIVY_APP_ID=
PRIVY_APP_SECRET=

# Twilio (SMS / OTP)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SID=

# WhatsApp Business API
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=

# TransFi (Off-ramp — primary)
TRANSFI_API_KEY=
TRANSFI_API_SECRET=
TRANSFI_WEBHOOK_SECRET=

# Stripe / Checkout.com (Cash-in)
STRIPE_API_KEY=
STRIPE_WEBHOOK_SECRET=
CHECKOUT_API_KEY=

# Persona (KYC)
PERSONA_API_KEY=
PERSONA_TEMPLATE_ID=
PERSONA_WEBHOOK_SECRET=

# ============================================
# Blockchain
# ============================================
SOLANA_RPC_URL=
SOLANA_USDC_MINT=EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v

# ============================================
# Auth + URLs
# ============================================
JWT_SECRET=
JWT_ACCESS_TOKEN_TTL=15m
JWT_REFRESH_TOKEN_TTL=7d

API_BASE_URL=https://api.ping.cash
WEB_URL=https://ping.cash
CLAIM_URL=https://ping.cash/c

# ============================================
# Observability (provided by Sovereign Grafana stack)
# ============================================
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=
SENTRY_DSN=

# ============================================
# Feature Flags
# ============================================
FEATURE_MULTI_CHAIN=false
FEATURE_BANK_OFFRAMP=true
FEATURE_RECURRING_TRANSFERS=false
