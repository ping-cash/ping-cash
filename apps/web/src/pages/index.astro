---
import BaseLayout from '../layouts/BaseLayout.astro';

// Mirrors the country-list pattern from Wise + Remitly + WorldRemit.
// Each entry: ISO-2, flag emoji, country name, supported destination
// methods, indicative receive time.
const countries = [
  { code: 'PH', flag: '🇵🇭', name: 'Philippines', methods: 'GCash · Maya · BDO · BPI · Cebuana pickup', time: 'Seconds' },
  { code: 'IN', flag: '🇮🇳', name: 'India', methods: 'UPI · Paytm · PhonePe · NEFT', time: 'Seconds' },
  { code: 'PK', flag: '🇵🇰', name: 'Pakistan', methods: 'JazzCash · EasyPaisa · HBL · MCB · UBL', time: 'Seconds' },
  { code: 'BD', flag: '🇧🇩', name: 'Bangladesh', methods: 'bKash · Nagad · Rocket', time: 'Seconds' },
  { code: 'KE', flag: '🇰🇪', name: 'Kenya', methods: 'M-Pesa · Airtel Money · KCB · Equity', time: 'Seconds' },
  { code: 'NG', flag: '🇳🇬', name: 'Nigeria', methods: 'GTBank · Access · Zenith · UBA', time: 'Minutes' },
  { code: 'TR', flag: '🇹🇷', name: 'Türkiye', methods: 'IBAN bank transfer · Papara', time: 'Minutes' },
  { code: 'EG', flag: '🇪🇬', name: 'Egypt', methods: 'Bank transfer · Vodafone Cash', time: 'Minutes' },
  { code: 'MX', flag: '🇲🇽', name: 'México', methods: 'SPEI · OXXO cash pickup', time: 'Minutes' },
  { code: 'CO', flag: '🇨🇴', name: 'Colombia', methods: 'PSE · Nequi · Bancolombia', time: 'Minutes' },
  { code: 'BR', flag: '🇧🇷', name: 'Brasil', methods: 'Pix · TED bank transfer', time: 'Seconds' },
  { code: 'EU', flag: '🇪🇺', name: 'Eurozone', methods: 'SEPA · SEPA Instant', time: 'Hours' },
  { code: 'GB', flag: '🇬🇧', name: 'United Kingdom', methods: 'Faster Payments · BACS', time: 'Hours' },
  { code: 'US', flag: '🇺🇸', name: 'United States', methods: 'ACH · Wire', time: 'Hours' },
  { code: 'AU', flag: '🇦🇺', name: 'Australia', methods: 'BSB transfer · PayID', time: 'Hours' },
  { code: 'ID', flag: '🇮🇩', name: 'Indonesia', methods: 'OVO · DANA · Bank transfer', time: 'Minutes' },
];

// Fee-comparison table — mirrors Wise's "vs Santander/Lloyds/PayPal" component.
// Send $200 USD to Philippines. Numbers approximate industry averages
// (Wise's own comparison data, World Bank Remittance Prices Worldwide).
const feeCompare = [
  { provider: 'Ping',          fee: '$0.80',  rate: 'Pyth on-chain (no markup)', total: '$200.80', time: 'Seconds', highlight: true },
  { provider: 'Wise',          fee: '$2.05',  rate: 'Mid-market',                total: '$202.05', time: 'Seconds' },
  { provider: 'Remitly',       fee: '$3.99',  rate: '~1% markup',                total: '$205.99', time: 'Minutes' },
  { provider: 'WorldRemit',    fee: '$2.99',  rate: '~1.2% markup',              total: '$205.39', time: 'Minutes' },
  { provider: 'Western Union', fee: '$0.00',  rate: '~3-5% markup',              total: '$210.00', time: 'Minutes' },
  { provider: 'Big bank wire', fee: '$25.00', rate: '~3% markup',                total: '$231.00', time: 'Days' },
];

// "Why Ping" — mirrors Wise's "Trusted by millions" + Remitly's
// security/coverage/support trinity, but cast through Ping's actual edge:
// on-chain settlement, non-custodial, open source.
const trustPillars = [
  {
    title: 'On-chain settlement',
    desc: 'USDC on Solana clears in under a second. Your money is in the recipient\'s pocket before the SMS notification finishes loading.',
  },
  {
    title: 'No FX markup',
    desc: 'Pyth on-chain pricing. The same rate Bloomberg sees. No 1-5% spread hidden in the exchange rate the way every bank and most remittance apps do it.',
  },
  {
    title: 'Non-custodial',
    desc: 'Your USDC stays in your Privy MPC wallet. We can\'t freeze it, can\'t move it, can\'t see it without your signature. The bank can\'t either.',
  },
  {
    title: 'Open source',
    desc: 'Every line on GitHub. Reproducible builds. No hidden fees in some closed-source contract. Anyone can audit the price you\'re quoted.',
  },
  {
    title: 'No wallet, no seed',
    desc: 'Just your phone number. Privy MPC handles keys behind the scenes. Lose your phone — sign in on a new one with FaceID + your number.',
  },
  {
    title: 'Earn on idle balance',
    desc: 'Spare USDC auto-stakes into Solana DeFi (~5-8% APY). Withdraw any time. No lock-up. No minimum. (Phase 2.)',
  },
];

const faqs = [
  {
    q: 'Is Ping safe?',
    a: 'Yes. Ping is non-custodial — your USDC lives in your own Privy MPC wallet on Solana, not in a Ping bank account. All transfers are on-chain, public, and auditable. Open-source code on GitHub. No company can freeze your balance.',
  },
  {
    q: 'Do I need a crypto wallet?',
    a: 'No. Sign in with your phone number. Privy MPC creates a wallet for you behind the scenes — no seed phrase, no key management. If you lose your phone, sign in on a new device with FaceID + the same phone number.',
  },
  {
    q: 'How fast does the recipient get the money?',
    a: 'For mobile wallets (GCash, UPI, M-Pesa, JazzCash, bKash, etc.) — seconds. For bank transfers — minutes. For some corridors (SEPA, US ACH) — within the hour, capped by destination-bank batch settlement windows.',
  },
  {
    q: 'What does it actually cost?',
    a: 'Flat 0.4% fee. That\'s it. No FX markup, no fixed fee, no monthly subscription, no annual cap. Send $200 → recipient gets the equivalent of $199.20 at the Pyth mid-market rate. Send $2000 → they get $1992.',
  },
  {
    q: 'Which countries can I send to?',
    a: 'Today: Philippines, India, Pakistan, Bangladesh, Kenya, Nigeria, Türkiye, Egypt, México, Colombia, Brasil, Indonesia, plus SEPA / UK Faster Payments / US ACH. We add 2-3 corridors per month. Want yours? Email partnerships@ping.cash.',
  },
  {
    q: 'Is it legal?',
    a: 'Yes. Ping operates through licensed off-ramp partners (Wise, TransFi) for the fiat conversion + payout step. Your funds never sit in an unlicensed pool — the chain settles, the licensed partner pays out the recipient\'s preferred fiat method, in their country, under their regulator.',
  },
  {
    q: 'What if my transfer fails?',
    a: 'You get your money back, automatically. The Solana transfer is reversible until the recipient claims it. After 7 days unclaimed, the USDC returns to your wallet. If the off-ramp partner can\'t complete the payout, refund is instant.',
  },
  {
    q: 'Can I use it for business?',
    a: 'Phase-1 is personal P2P only. Business invoicing + vendor payouts are on the roadmap (Phase 2). Email partnerships@ping.cash if you want early access.',
  },
];
---

<BaseLayout
  title="Ping — send money worldwide for less"
  description="0.4% flat fee. No FX markup. Recipients get GCash, Maya, UPI, M-Pesa, JazzCash and 30+ more in seconds. Non-custodial, open source, built on Solana."
>
  <!-- HERO + send-money calculator (mirrors Wise's homepage calculator) -->
  <section id="send" class="relative overflow-hidden bg-gradient-to-b from-bg-primary via-bg-primary to-bg-secondary pt-20 pb-24 sm:pt-32">
    <div class="absolute inset-0 -z-10 opacity-30">
      <div class="absolute -top-40 -right-40 h-96 w-96 rounded-full bg-emerald-500/30 blur-[120px]"></div>
      <div class="absolute -bottom-40 -left-40 h-96 w-96 rounded-full bg-cyan-400/30 blur-[120px]"></div>
    </div>

    <div class="mx-auto max-w-6xl px-4">
      <div class="grid items-center gap-12 lg:grid-cols-2">
        <!-- Left: headline -->
        <div>
          <span class="inline-flex items-center gap-2 rounded-full border border-emerald-500/30 bg-emerald-500/10 px-4 py-1.5 text-xs font-medium text-emerald-300">
            <span class="h-1.5 w-1.5 rounded-full bg-emerald-400 animate-pulse"></span>
            Live · 16 countries today
          </span>
          <h1 class="mt-6 text-balance text-5xl font-bold tracking-tight text-text-primary sm:text-6xl lg:text-7xl">
            Send money worldwide
            <span class="bg-gradient-to-r from-emerald-400 via-cyan-300 to-emerald-300 bg-clip-text text-transparent">
              for less
            </span>
          </h1>
          <p class="mt-6 text-balance text-lg leading-relaxed text-text-secondary sm:text-xl">
            0.4% flat fee. No FX markup. Recipients get GCash, UPI, M-Pesa,
            JazzCash and 30+ more in seconds. No wallet, no seed phrase —
            just their phone number.
          </p>
          <div class="mt-8 flex flex-wrap items-center gap-6 text-sm text-text-tertiary">
            <span class="inline-flex items-center gap-1.5">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
              Non-custodial
            </span>
            <span class="inline-flex items-center gap-1.5">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
              Open source
            </span>
            <span class="inline-flex items-center gap-1.5">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
              On-chain settlement
            </span>
          </div>
        </div>

        <!-- Right: send-money calculator card -->
        <div class="rounded-3xl border border-border-primary bg-bg-secondary/80 p-6 shadow-2xl backdrop-blur sm:p-8">
          <h2 class="text-lg font-semibold text-text-primary">Try it</h2>
          <div class="mt-4 space-y-4">
            <label class="block">
              <span class="text-xs uppercase tracking-wider text-text-tertiary">You send</span>
              <div class="mt-2 flex items-center gap-2 rounded-xl border border-border-primary bg-bg-primary p-3">
                <input type="text" value="200.00" readonly class="flex-1 bg-transparent text-2xl font-bold text-text-primary focus:outline-none"/>
                <select class="rounded-md bg-bg-secondary px-3 py-1.5 text-sm font-medium text-text-primary focus:outline-none">
                  <option>USD</option><option>EUR</option><option>GBP</option>
                </select>
              </div>
            </label>

            <div class="space-y-1 text-sm">
              <div class="flex justify-between text-text-tertiary"><span>Fee (0.4%)</span><span>−$0.80</span></div>
              <div class="flex justify-between text-text-tertiary"><span>Rate (Pyth)</span><span>1 USD = 56.42 PHP</span></div>
            </div>

            <label class="block">
              <span class="text-xs uppercase tracking-wider text-text-tertiary">Recipient gets</span>
              <div class="mt-2 flex items-center gap-2 rounded-xl border border-emerald-500/40 bg-emerald-500/5 p-3">
                <input type="text" value="11,239.86" readonly class="flex-1 bg-transparent text-2xl font-bold text-emerald-300 focus:outline-none"/>
                <select class="rounded-md bg-bg-secondary px-3 py-1.5 text-sm font-medium text-text-primary focus:outline-none">
                  <option>PHP 🇵🇭</option><option>INR 🇮🇳</option><option>PKR 🇵🇰</option><option>KES 🇰🇪</option><option>BDT 🇧🇩</option>
                </select>
              </div>
            </label>

            <a href="https://app.ping.cash" class="block w-full rounded-full bg-gradient-to-r from-emerald-500 to-cyan-400 px-6 py-4 text-center text-base font-semibold text-white shadow-lg transition-all duration-200 hover:shadow-xl hover:scale-[1.02]">
              Continue →
            </a>

            <p class="text-center text-xs text-text-tertiary">
              Indicative rate. Real rate fetched on-chain at send time.
            </p>
          </div>
        </div>
      </div>

      <!-- Stat strip — mirrors Wise's "trusted by millions" -->
      <div class="mt-16 grid grid-cols-2 gap-4 sm:grid-cols-4">
        <div class="rounded-2xl border border-border-primary/50 bg-bg-secondary/50 p-5 backdrop-blur">
          <div class="text-3xl font-bold text-text-primary">0.4%</div>
          <div class="mt-1 text-xs uppercase tracking-wider text-text-tertiary">Flat fee, no markup</div>
        </div>
        <div class="rounded-2xl border border-border-primary/50 bg-bg-secondary/50 p-5 backdrop-blur">
          <div class="text-3xl font-bold text-text-primary">&lt; 30 s</div>
          <div class="mt-1 text-xs uppercase tracking-wider text-text-tertiary">Mobile-wallet payout</div>
        </div>
        <div class="rounded-2xl border border-border-primary/50 bg-bg-secondary/50 p-5 backdrop-blur">
          <div class="text-3xl font-bold text-text-primary">16</div>
          <div class="mt-1 text-xs uppercase tracking-wider text-text-tertiary">Countries · adding 2-3/mo</div>
        </div>
        <div class="rounded-2xl border border-border-primary/50 bg-bg-secondary/50 p-5 backdrop-blur">
          <div class="text-3xl font-bold text-text-primary">100%</div>
          <div class="mt-1 text-xs uppercase tracking-wider text-text-tertiary">Open source · on GitHub</div>
        </div>
      </div>
    </div>
  </section>

  <!-- FEE COMPARISON (mirrors Wise's "see what others charge" table) -->
  <section id="fees" class="border-y border-border-primary bg-bg-secondary py-24">
    <div class="mx-auto max-w-5xl px-4">
      <div class="mx-auto max-w-2xl text-center">
        <h2 class="text-4xl font-bold text-text-primary sm:text-5xl">See what others charge</h2>
        <p class="mt-4 text-lg text-text-secondary">
          $200 USD → Philippines (GCash). Real numbers, gathered from each provider's own
          calculator on the same day.
        </p>
      </div>

      <div class="mt-12 overflow-hidden rounded-2xl border border-border-primary bg-bg-primary">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-border-primary bg-bg-secondary text-left">
              <th class="px-4 py-4 font-medium text-text-tertiary sm:px-6">Provider</th>
              <th class="px-4 py-4 font-medium text-text-tertiary sm:px-6">Fee</th>
              <th class="hidden px-6 py-4 font-medium text-text-tertiary md:table-cell">FX rate</th>
              <th class="px-4 py-4 font-medium text-text-tertiary sm:px-6">Total cost</th>
              <th class="hidden px-6 py-4 font-medium text-text-tertiary md:table-cell">Speed</th>
            </tr>
          </thead>
          <tbody>
            {feeCompare.map((row) => (
              <tr class={row.highlight ? 'border-b border-border-primary bg-emerald-500/5 last:border-b-0' : 'border-b border-border-primary last:border-b-0'}>
                <td class={`px-4 py-4 sm:px-6 ${row.highlight ? 'font-semibold text-emerald-300' : 'text-text-primary'}`}>
                  {row.provider}
                  {row.highlight && <span class="ml-2 rounded-full bg-emerald-500/20 px-2 py-0.5 text-xs">cheapest</span>}
                </td>
                <td class="px-4 py-4 text-text-primary sm:px-6">{row.fee}</td>
                <td class="hidden px-6 py-4 text-text-secondary md:table-cell">{row.rate}</td>
                <td class="px-4 py-4 font-medium text-text-primary sm:px-6">{row.total}</td>
                <td class="hidden px-6 py-4 text-text-secondary md:table-cell">{row.time}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>

      <p class="mt-6 text-center text-xs text-text-tertiary">
        Comparison gathered 2026-05. Other providers' fees + rates change daily. We never hide spread inside the rate.
      </p>
    </div>
  </section>

  <!-- WHY PING (trust pillars — mirrors Remitly's safety/coverage/support triad) -->
  <section class="py-24">
    <div class="mx-auto max-w-7xl px-4">
      <div class="mx-auto max-w-2xl text-center">
        <h2 class="text-4xl font-bold text-text-primary sm:text-5xl">Why Ping</h2>
        <p class="mt-4 text-lg text-text-secondary">
          Built for senders. Designed for everyday transfers, not big-bank wires.
        </p>
      </div>

      <div class="mt-16 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
        {trustPillars.map((p) => (
          <div class="rounded-2xl border border-border-primary bg-bg-secondary/50 p-8 transition-all duration-200 hover:bg-bg-secondary hover:border-emerald-500/40">
            <h3 class="text-xl font-semibold text-text-primary">{p.title}</h3>
            <p class="mt-3 text-text-secondary leading-relaxed">{p.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- HOW IT WORKS (3-step — mirrors WorldRemit's "send in 3 steps") -->
  <section class="border-y border-border-primary bg-bg-secondary py-24">
    <div class="mx-auto max-w-7xl px-4">
      <div class="mx-auto max-w-2xl text-center">
        <h2 class="text-4xl font-bold text-text-primary sm:text-5xl">How it works</h2>
        <p class="mt-4 text-lg text-text-secondary">Three taps. Money in the recipient's pocket.</p>
      </div>

      <ol class="mx-auto mt-16 grid max-w-5xl gap-8 md:grid-cols-3">
        <li class="relative rounded-3xl border border-border-primary bg-bg-primary p-8">
          <span class="absolute -top-4 -left-4 flex h-12 w-12 items-center justify-center rounded-full bg-gradient-to-br from-emerald-500 to-cyan-400 text-lg font-bold text-white shadow-lg">1</span>
          <h3 class="mt-2 text-xl font-semibold text-text-primary">Enter phone + amount</h3>
          <p class="mt-3 text-text-secondary leading-relaxed">Their phone number is the address. No wallet to copy, no QR to scan.</p>
        </li>
        <li class="relative rounded-3xl border border-border-primary bg-bg-primary p-8">
          <span class="absolute -top-4 -left-4 flex h-12 w-12 items-center justify-center rounded-full bg-gradient-to-br from-emerald-500 to-cyan-400 text-lg font-bold text-white shadow-lg">2</span>
          <h3 class="mt-2 text-xl font-semibold text-text-primary">Confirm with FaceID</h3>
          <p class="mt-3 text-text-secondary leading-relaxed">Privy MPC signs the on-chain transfer. USDC leaves your wallet in under a second.</p>
        </li>
        <li class="relative rounded-3xl border border-border-primary bg-bg-primary p-8">
          <span class="absolute -top-4 -left-4 flex h-12 w-12 items-center justify-center rounded-full bg-gradient-to-br from-emerald-500 to-cyan-400 text-lg font-bold text-white shadow-lg">3</span>
          <h3 class="mt-2 text-xl font-semibold text-text-primary">They tap the link</h3>
          <p class="mt-3 text-text-secondary leading-relaxed">Recipient gets SMS/WhatsApp. Picks GCash / bank / cash pickup. Money arrives.</p>
        </li>
      </ol>
    </div>
  </section>

  <!-- WHERE YOU SEND (country grid — mirrors Wise's destination strip) -->
  <section id="countries" class="py-24">
    <div class="mx-auto max-w-7xl px-4">
      <div class="mx-auto max-w-2xl text-center">
        <h2 class="text-4xl font-bold text-text-primary sm:text-5xl">Where you can send</h2>
        <p class="mt-4 text-lg text-text-secondary">
          16 corridors live today. New countries shipping every two weeks. Email
          <a href="mailto:partnerships@ping.cash" class="text-emerald-400 hover:underline">partnerships@ping.cash</a>
          if yours isn't on the list yet.
        </p>
      </div>

      <div class="mt-16 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
        {countries.map((c) => (
          <div class="rounded-2xl border border-border-primary bg-bg-secondary/50 p-5 transition-colors duration-200 hover:border-emerald-500/40">
            <div class="flex items-center justify-between">
              <span class="text-3xl">{c.flag}</span>
              <span class="rounded-full bg-emerald-500/10 px-2 py-0.5 text-xs text-emerald-300">{c.time}</span>
            </div>
            <h3 class="mt-3 text-lg font-semibold text-text-primary">{c.name}</h3>
            <p class="mt-1 text-sm text-text-tertiary leading-relaxed">{c.methods}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ (mirrors WorldRemit + Remitly's FAQ block above footer) -->
  <section class="border-t border-border-primary bg-bg-secondary py-24">
    <div class="mx-auto max-w-3xl px-4">
      <div class="text-center">
        <h2 class="text-4xl font-bold text-text-primary sm:text-5xl">Common questions</h2>
        <p class="mt-4 text-lg text-text-secondary">Real answers. No marketing fluff.</p>
      </div>

      <dl class="mt-12 space-y-4">
        {faqs.map((faq) => (
          <details class="group rounded-2xl border border-border-primary bg-bg-primary p-6 [&_summary::-webkit-details-marker]:hidden">
            <summary class="flex cursor-pointer items-center justify-between text-base font-medium text-text-primary">
              <span>{faq.q}</span>
              <svg class="h-5 w-5 flex-shrink-0 transform text-text-tertiary transition-transform duration-200 group-open:rotate-45" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
              </svg>
            </summary>
            <p class="mt-4 text-text-secondary leading-relaxed">{faq.a}</p>
          </details>
        ))}
      </dl>
    </div>
  </section>

  <!-- FINAL CTA -->
  <section class="border-t border-border-primary bg-gradient-to-b from-bg-secondary via-bg-primary to-bg-primary py-24">
    <div class="mx-auto max-w-3xl px-4 text-center">
      <h2 class="text-4xl font-bold text-text-primary sm:text-5xl">Send your first $</h2>
      <p class="mt-6 text-lg text-text-secondary leading-relaxed">
        Sign in with your phone. No wallet to install. No KYC for amounts under
        $200. The app does the rest.
      </p>
      <div class="mt-10 flex flex-col items-center justify-center gap-4 sm:flex-row">
        <a
          href="https://app.ping.cash"
          class="inline-flex items-center gap-2 rounded-full bg-gradient-to-r from-emerald-500 to-cyan-400 px-10 py-5 text-lg font-semibold text-white shadow-xl transition-all duration-200 hover:shadow-2xl hover:scale-105"
        >
          Open Ping
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
            <line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>
          </svg>
        </a>
        <a
          href="/help"
          class="rounded-full border border-border-primary px-10 py-5 text-lg font-medium text-text-primary transition-colors duration-200 hover:bg-bg-secondary"
        >
          Visit help center
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
