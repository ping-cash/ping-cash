# ============================================
# Cash Platform Environment Variables
# ============================================
# Copy this file to .env and fill in the values

# Environment
NODE_ENV=development

# ============================================
# Database Configuration
# ============================================

# PostgreSQL (Ledger, Transfer, KYC)
POSTGRES_URL=postgresql://cash:cash@localhost:5432/cash?schema=public
POSTGRES_URL_NON_POOLING=postgresql://cash:cash@localhost:5432/cash?schema=public

# MongoDB (User, Claim, Notify)
MONGODB_URL=mongodb://cash:cash@localhost:27017/cash?authSource=admin

# Redis (Sessions, Cache)
REDIS_URL=redis://localhost:6379

# ============================================
# Message Queue
# ============================================

# Kafka/Redpanda
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=cash-platform
KAFKA_GROUP_ID=cash-consumers

# ============================================
# External Services
# ============================================

# Privy (Wallet Infrastructure)
PRIVY_APP_ID=
PRIVY_APP_SECRET=

# Twilio (SMS/OTP)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SID=

# WhatsApp Business API
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=

# TransFi (Off-ramp)
TRANSFI_API_KEY=
TRANSFI_API_SECRET=
TRANSFI_WEBHOOK_SECRET=

# MoonPay (On-ramp)
MOONPAY_API_KEY=
MOONPAY_SECRET_KEY=
MOONPAY_WEBHOOK_SECRET=

# Persona (KYC)
PERSONA_API_KEY=
PERSONA_TEMPLATE_ID=
PERSONA_WEBHOOK_SECRET=

# ============================================
# Blockchain
# ============================================

# Solana
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
SOLANA_USDC_MINT=EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v

# ============================================
# Application Configuration
# ============================================

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_ACCESS_TOKEN_TTL=15m
JWT_REFRESH_TOKEN_TTL=7d

# API
API_PORT=3000
API_BASE_URL=http://localhost:3000

# Web App
WEB_URL=http://localhost:3001
CLAIM_URL=http://localhost:3001/c

# ============================================
# Observability
# ============================================

# Logging
LOG_LEVEL=debug

# OpenTelemetry
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=cash-platform

# Sentry (Error Tracking)
SENTRY_DSN=

# ============================================
# Feature Flags
# ============================================

FEATURE_MULTI_CHAIN=false
FEATURE_BANK_OFFRAMP=false
FEATURE_RECURRING_TRANSFERS=false
