{
  "name": "@cash/transfer-service",
  "version": "0.1.0",
  "private": true,
  "description": "Transfer orchestration service",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch --onSuccess \"node dist/index.js\"",
    "start": "node dist/index.js",
    "test": "vitest",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "clean": "rm -rf dist",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate deploy",
    "db:push": "prisma db push",
    "docker:build": "docker build -t cash/transfer-service .",
    "docker:push": "docker push cash/transfer-service"
  },
  "dependencies": {
    "@cash/config": "workspace:*",
    "@cash/types": "workspace:*",
    "@cash/utils": "workspace:*",
    "@fastify/cors": "^9.0.0",
    "@fastify/helmet": "^11.0.0",
    "@fastify/rate-limit": "^9.0.0",
    "@prisma/client": "^5.10.0",
    "fastify": "^4.26.0",
    "kafkajs": "^2.2.4",
    "ioredis": "^5.3.0",
    "pino": "^8.19.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "prisma": "^5.10.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.3.0"
  }
}
