{
  "name": "@ping/types",
  "version": "0.1.0",
  "private": true,
  "description": "Shared TypeScript types and interfaces",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./events": {
      "import": "./dist/events.mjs",
      "require": "./dist/events.js",
      "types": "./dist/events.d.ts"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "@ping/config": "workspace:*",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0"
  }
}