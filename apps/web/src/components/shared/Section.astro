---
interface Props {
  id?: string;
  class?: string;
  bg?: 'primary' | 'secondary';
  reveal?: boolean;
}

const { id, class: className, bg = 'primary', reveal = true } = Astro.props;
const bgClass = bg === 'secondary' ? 'bg-bg-secondary' : 'bg-bg-primary';
---

<section
  id={id}
  class:list={[
    'py-20 md:py-28 px-4',
    bgClass,
    reveal && 'reveal',
    className,
  ]}
>
  <div class="mx-auto max-w-7xl">
    <slot />
  </div>
</section>
