---
import BaseLayout from '../layouts/BaseLayout.astro';

const features = [
  {
    title: '0.4% flat fee',
    desc: 'No FX markup. Pyth on-chain pricing. The whole industry charges 7-15%. We charge what it actually costs us to move dollars.',
  },
  {
    title: 'Cash in seconds',
    desc: 'Recipient gets a link. Picks GCash / Maya / bank / cash pickup. Money arrives before they finish the OTP.',
  },
  {
    title: 'No wallet, no seed',
    desc: 'Just your phone number. Privy MPC handles keys. Lose your phone — your money is still safe.',
  },
  {
    title: 'Earn yield on idle USDC',
    desc: 'Spare cash auto-earns ~5-8% via Solana DeFi. Withdraw any time. No lock-up, no minimum.',
  },
  {
    title: 'Works to 30+ countries',
    desc: 'PH, IN, PK, BD, KE, TR, SG, ID, NG... new corridors added monthly. SEPA, US ACH, UK Faster Payments included.',
  },
  {
    title: 'Open source',
    desc: 'All code on GitHub. Built on the openova.io platform. Non-custodial — we never touch your funds.',
  },
];

const corridors = [
  { flag: '🇵🇭', country: 'Philippines', methods: 'GCash · Maya · BDO · BPI · Cebuana pickup' },
  { flag: '🇮🇳', country: 'India', methods: 'UPI · Paytm · PhonePe · NEFT' },
  { flag: '🇵🇰', country: 'Pakistan', methods: 'JazzCash · EasyPaisa · HBL · MCB · UBL' },
  { flag: '🇧🇩', country: 'Bangladesh', methods: 'bKash · Nagad · Rocket' },
  { flag: '🇰🇪', country: 'Kenya', methods: 'M-Pesa · Airtel Money · KCB · Equity' },
  { flag: '🇹🇷', country: 'Türkiye', methods: 'IBAN bank transfer' },
  { flag: '🇪🇺', country: 'EU/UK/US', methods: 'SEPA · UK Faster Payments · US ACH (via Wise)' },
  { flag: '🌍', country: '+ 20 more', methods: 'Adding 2-3 corridors/month' },
];
---

<BaseLayout
  title="Ping — send money instantly worldwide"
  description="0.4% flat fee. Recipients get GCash, Maya, UPI, M-Pesa, JazzCash and 30+ more in seconds. No wallet, no seed phrase — just your phone number."
>
  <!-- HERO -->
  <section class="relative overflow-hidden bg-gradient-to-b from-bg-primary via-bg-primary to-bg-secondary pt-20 pb-32 sm:pt-32 sm:pb-40">
    <div class="absolute inset-0 -z-10 opacity-30">
      <div class="absolute -top-40 -right-40 h-96 w-96 rounded-full bg-emerald-500/30 blur-[120px]"></div>
      <div class="absolute -bottom-40 -left-40 h-96 w-96 rounded-full bg-cyan-400/30 blur-[120px]"></div>
    </div>

    <div class="mx-auto max-w-5xl px-4 text-center">
      <span class="inline-flex items-center gap-2 rounded-full border border-emerald-500/30 bg-emerald-500/10 px-4 py-1.5 text-xs font-medium text-emerald-300">
        <span class="h-1.5 w-1.5 rounded-full bg-emerald-400 animate-pulse"></span>
        Live · serving 5 corridors today
      </span>

      <h1 class="mt-8 text-balance text-5xl font-bold tracking-tight text-text-primary sm:text-7xl">
        Send money <span class="bg-gradient-to-r from-emerald-400 via-cyan-300 to-emerald-300 bg-clip-text text-transparent">like a message</span>
      </h1>

      <p class="mx-auto mt-8 max-w-2xl text-balance text-lg leading-relaxed text-text-secondary sm:text-xl">
        Recipients get GCash, Maya, UPI, M-Pesa, JazzCash and 30+ more in seconds.
        0.4% flat fee. No FX markup. No wallet, no seed phrase — just their phone number.
      </p>

      <div class="mt-12 flex flex-col items-center gap-4 sm:flex-row sm:justify-center">
        <a
          href="https://ping.openova.io"
          class="inline-flex items-center gap-2 rounded-full bg-gradient-to-r from-emerald-500 to-cyan-400 px-8 py-4 text-base font-medium text-white shadow-lg transition-all duration-200 hover:shadow-xl hover:scale-105"
        >
          Send your first $
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
            <line x1="5" y1="12" x2="19" y2="12" />
            <polyline points="12 5 19 12 12 19" />
          </svg>
        </a>
        <a
          href="#how-it-works"
          class="inline-flex items-center gap-2 rounded-full border border-border-primary px-8 py-4 text-base font-medium text-text-primary transition-colors duration-200 hover:bg-bg-secondary"
        >
          How it works
        </a>
      </div>

      <div class="mt-16 grid grid-cols-2 gap-6 sm:grid-cols-4">
        <div class="rounded-2xl border border-border-primary/50 bg-bg-secondary/50 p-6 backdrop-blur">
          <div class="text-3xl font-bold text-text-primary sm:text-4xl">0.4%</div>
          <div class="mt-1 text-xs uppercase tracking-wider text-text-tertiary">Flat fee</div>
        </div>
        <div class="rounded-2xl border border-border-primary/50 bg-bg-secondary/50 p-6 backdrop-blur">
          <div class="text-3xl font-bold text-text-primary sm:text-4xl">&lt; 30s</div>
          <div class="mt-1 text-xs uppercase tracking-wider text-text-tertiary">Settlement</div>
        </div>
        <div class="rounded-2xl border border-border-primary/50 bg-bg-secondary/50 p-6 backdrop-blur">
          <div class="text-3xl font-bold text-text-primary sm:text-4xl">5+</div>
          <div class="mt-1 text-xs uppercase tracking-wider text-text-tertiary">Corridors live</div>
        </div>
        <div class="rounded-2xl border border-border-primary/50 bg-bg-secondary/50 p-6 backdrop-blur">
          <div class="text-3xl font-bold text-text-primary sm:text-4xl">~7%</div>
          <div class="mt-1 text-xs uppercase tracking-wider text-text-tertiary">Industry avg fee</div>
        </div>
      </div>
    </div>
  </section>

  <!-- HOW IT WORKS -->
  <section id="how-it-works" class="border-y border-border-primary bg-bg-secondary py-24">
    <div class="mx-auto max-w-7xl px-4">
      <div class="mx-auto max-w-2xl text-center">
        <h2 class="text-4xl font-bold text-text-primary sm:text-5xl">How it works</h2>
        <p class="mt-4 text-lg text-text-secondary">Three taps. Money in the recipient's pocket.</p>
      </div>

      <ol class="mx-auto mt-16 grid max-w-5xl gap-8 md:grid-cols-3">
        <li class="relative rounded-3xl border border-border-primary bg-bg-primary p-8">
          <span class="absolute -top-4 -left-4 flex h-12 w-12 items-center justify-center rounded-full bg-gradient-to-br from-emerald-500 to-cyan-400 text-lg font-bold text-white shadow-lg">1</span>
          <h3 class="mt-2 text-xl font-semibold text-text-primary">Enter phone + amount</h3>
          <p class="mt-3 text-text-secondary leading-relaxed">Their phone number is the address. No wallet to copy, no QR to scan.</p>
        </li>
        <li class="relative rounded-3xl border border-border-primary bg-bg-primary p-8">
          <span class="absolute -top-4 -left-4 flex h-12 w-12 items-center justify-center rounded-full bg-gradient-to-br from-emerald-500 to-cyan-400 text-lg font-bold text-white shadow-lg">2</span>
          <h3 class="mt-2 text-xl font-semibold text-text-primary">Confirm with FaceID</h3>
          <p class="mt-3 text-text-secondary leading-relaxed">Privy MPC signs the on-chain transfer. USDC leaves your account.</p>
        </li>
        <li class="relative rounded-3xl border border-border-primary bg-bg-primary p-8">
          <span class="absolute -top-4 -left-4 flex h-12 w-12 items-center justify-center rounded-full bg-gradient-to-br from-emerald-500 to-cyan-400 text-lg font-bold text-white shadow-lg">3</span>
          <h3 class="mt-2 text-xl font-semibold text-text-primary">They tap the link</h3>
          <p class="mt-3 text-text-secondary leading-relaxed">Recipient gets SMS/WhatsApp. Picks GCash / bank / pickup. Done.</p>
        </li>
      </ol>
    </div>
  </section>

  <!-- FEATURES -->
  <section class="py-24">
    <div class="mx-auto max-w-7xl px-4">
      <div class="mx-auto max-w-2xl text-center">
        <h2 class="text-4xl font-bold text-text-primary sm:text-5xl">Why Ping</h2>
        <p class="mt-4 text-lg text-text-secondary">Built for senders. Designed for everyday transfers, not big-bank wires.</p>
      </div>

      <div class="mt-16 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
        {features.map((feat) => (
          <div class="rounded-2xl border border-border-primary bg-bg-secondary/50 p-8 transition-all duration-200 hover:bg-bg-secondary hover:border-emerald-500/40">
            <h3 class="text-xl font-semibold text-text-primary">{feat.title}</h3>
            <p class="mt-3 text-text-secondary leading-relaxed">{feat.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CORRIDORS -->
  <section id="corridors" class="border-y border-border-primary bg-bg-secondary py-24">
    <div class="mx-auto max-w-7xl px-4">
      <div class="mx-auto max-w-2xl text-center">
        <h2 class="text-4xl font-bold text-text-primary sm:text-5xl">Where you can send</h2>
        <p class="mt-4 text-lg text-text-secondary">From anywhere with internet. To anyone with a phone.</p>
      </div>

      <div class="mt-16 grid gap-4 md:grid-cols-2 lg:grid-cols-4">
        {corridors.map((c) => (
          <div class="rounded-2xl border border-border-primary bg-bg-primary p-6">
            <div class="text-3xl">{c.flag}</div>
            <h3 class="mt-3 text-lg font-semibold text-text-primary">{c.country}</h3>
            <p class="mt-2 text-sm text-text-tertiary leading-relaxed">{c.methods}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- EARN -->
  <section id="earn" class="py-24">
    <div class="mx-auto max-w-5xl px-4">
      <div class="rounded-3xl border border-border-primary bg-gradient-to-br from-emerald-500/10 via-bg-primary to-cyan-400/10 p-12 text-center sm:p-16">
        <span class="inline-flex items-center gap-2 rounded-full border border-cyan-400/30 bg-cyan-400/10 px-4 py-1.5 text-xs font-medium text-cyan-300">
          Coming with Phase 2
        </span>
        <h2 class="mt-6 text-4xl font-bold text-text-primary sm:text-5xl">
          Idle dollars earn <span class="bg-gradient-to-r from-emerald-400 to-cyan-300 bg-clip-text text-transparent">~5-8%</span>
        </h2>
        <p class="mx-auto mt-6 max-w-2xl text-lg text-text-secondary leading-relaxed">
          Spare USDC auto-stakes into Kamino, Marginfi, Aave and Drift. You see one
          unified balance — we hide the DeFi complexity. Withdraw any time. No lock-up.
          Yield in your pocket, not ours.
        </p>
        <div class="mt-8 grid gap-6 sm:grid-cols-3">
          <div>
            <div class="text-3xl font-bold text-text-primary">Auto</div>
            <div class="mt-1 text-sm text-text-tertiary">Compounding</div>
          </div>
          <div>
            <div class="text-3xl font-bold text-text-primary">4 protocols</div>
            <div class="mt-1 text-sm text-text-tertiary">Diversified</div>
          </div>
          <div>
            <div class="text-3xl font-bold text-text-primary">40/60</div>
            <div class="mt-1 text-sm text-text-tertiary">Treasury / holder split</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- FINAL CTA -->
  <section class="border-t border-border-primary bg-bg-secondary py-24">
    <div class="mx-auto max-w-3xl px-4 text-center">
      <h2 class="text-4xl font-bold text-text-primary sm:text-5xl">
        Send your first $
      </h2>
      <p class="mt-6 text-lg text-text-secondary leading-relaxed">
        No wallet. No KYC for amounts under $200. No seed phrase to lose.
        Sign in with your phone. The app does the rest.
      </p>
      <div class="mt-10">
        <a
          href="https://ping.openova.io"
          class="inline-flex items-center gap-2 rounded-full bg-gradient-to-r from-emerald-500 to-cyan-400 px-10 py-5 text-lg font-medium text-white shadow-xl transition-all duration-200 hover:shadow-2xl hover:scale-105"
        >
          Open Ping
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
            <line x1="5" y1="12" x2="19" y2="12" />
            <polyline points="12 5 19 12 12 19" />
          </svg>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
