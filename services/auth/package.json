{
  "name": "@ping/auth-service",
  "version": "0.1.0",
  "private": true,
  "description": "Phone OTP \u2192 Twilio Verify \u2192 JWT \u2192 Privy wallet creation",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch --onSuccess \"node dist/index.js\"",
    "start": "node dist/index.js",
    "test": "vitest",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@ping/config": "workspace:*",
    "@ping/types": "workspace:*",
    "@ping/utils": "workspace:*",
    "@fastify/cors": "^9.0.0",
    "@fastify/helmet": "^11.0.0",
    "@fastify/jwt": "^8.0.0",
    "@fastify/rate-limit": "^9.0.0",
    "@privy-io/server-auth": "^1.6.0",
    "fastify": "^4.26.0",
    "ioredis": "^5.3.0",
    "jsonwebtoken": "^9.0.2",
    "pino": "^8.19.0",
    "twilio": "^5.0.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^20.11.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.3.0"
  }
}