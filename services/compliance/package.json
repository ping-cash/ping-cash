{
  "name": "@ping/compliance-service",
  "version": "0.1.0",
  "private": true,
  "description": "Sanctions screening (Chainalysis KYT) + AML monitoring",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch --onSuccess \"node dist/index.js\"",
    "start": "node dist/index.js",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "clean": "rm -rf dist",
    "lint:fix": "eslint src/ --fix"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.0",
    "@fastify/helmet": "^11.0.0",
    "@ping/config": "workspace:*",
    "@ping/types": "workspace:*",
    "@ping/utils": "workspace:*",
    "fastify": "^4.26.0",
    "ioredis": "^5.8.2",
    "pino": "^8.19.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.3.0"
  }
}
