{
  "name": "@ping/wallet-service",
  "version": "0.1.0",
  "private": true,
  "description": "Wallet indexer \u2014 Privy MPC + external wallets, vUSDC + $PING balance, Earn Vault interaction",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch --onSuccess \"node dist/index.js\"",
    "start": "node dist/index.js",
    "test": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@ping/config": "workspace:*",
    "@ping/types": "workspace:*",
    "@ping/utils": "workspace:*",
    "@fastify/cors": "^9.0.0",
    "@fastify/helmet": "^11.0.0",
    "@fastify/jwt": "^8.0.0",
    "@fastify/rate-limit": "^9.0.0",
    "@solana/spl-token": "^0.4.0",
    "@solana/web3.js": "^1.92.0",
    "@privy-io/server-auth": "^1.6.0",
    "fastify": "^4.26.0",
    "ioredis": "^5.3.0",
    "pino": "^8.19.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.3.0"
  }
}