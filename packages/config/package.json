{
  "name": "@ping/config",
  "version": "0.1.0",
  "private": true,
  "description": "Shared configuration and environment utilities",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./eslint": "./eslint.js",
    "./typescript/base": "./typescript/base.json",
    "./typescript/base.json": "./typescript/base.json",
    "./typescript/node": "./typescript/node.json",
    "./typescript/node.json": "./typescript/node.json",
    "./typescript/react": "./typescript/react.json",
    "./typescript/react.json": "./typescript/react.json"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.4.0"
  }
}